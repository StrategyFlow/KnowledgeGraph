# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Ollama-Compatible API Configuration
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_API_KEY=your_api_key_here
OLLAMA_MODEL=gemma3:latest

# FalkorDB Configuration
USE_FALKORDB=true
AUTO_LOAD_FALKORDB=true
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=KnowledgeGraph
# Optional UI URL template printed after successful graph load
# Supported placeholders: {host}, {port}, {graph}
FALKORDB_BROWSER_URL=

# Input Processing Configuration
INPUT_DIR=input
WATCH_INPUT_FILES=false
